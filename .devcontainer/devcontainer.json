{
  "name": "PocketZena",
  "dockerComposeFile": "docker-compose.yml",
  "service": "development",
  "workspaceFolder": "/app",
  "forwardPorts": [8000, 8080],
  "portsAttributes": {
    "8000": { "label": "Backend (FastAPI)", "onAutoForward": "notify" },
    "8080": { "label": "Frontend (nginx)", "onAutoForward": "openBrowser" }
  },
  "postCreateCommand": "pip3.14 install -r /app/requirements.txt",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python3.14",
        "python.terminal.activateEnvironment": false
      }
    }
  },
  "remoteUser": "root"
}
